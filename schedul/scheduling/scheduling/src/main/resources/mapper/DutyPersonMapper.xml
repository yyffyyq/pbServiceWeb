<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.zjintu.schedul.mapper.duty.DutyPersonMapper">
    <update id="updateByPersonIdIsDelete">
        update duty_person
        set isDelete = 0
        where userId = #{userId}
    </update>
</mapper>
